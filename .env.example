# DeployIQ — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...          # safe to expose in browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # NEVER expose — backend only

# ── Frontend (Vite) — prefix with VITE_ ──────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── FastAPI Backend ───────────────────────────────────────────
OPENAI_API_KEY=sk-...             # for text-embedding-3-small
ANTHROPIC_API_KEY=sk-ant-...      # for Claude Sonnet 4.6
WEBHOOK_SECRET=your-random-secret # shared with GitHub Actions / Jenkins

# ── Optional ──────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
MISTRAL_API_KEY=...               # fallback LLM
